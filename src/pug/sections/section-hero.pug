.section-hero 
	//- Фоновое изображение (Абсолютное позиционирование)
		.section-hero__bg
	.section-hero__image.parallax
		+picture('/img/about/kuhnarenko.png', 'Максим Кушнаренко')
	//- Затемнение, чтобы текст читался на фото
	.section-hero__overlay

	.section-hero__body._container
		.section-hero__info
			.section-hero__content
				//- Верхняя метка (Имя)
				.section-hero__top-tag
					span.section-hero__name-label Максим Кушнаренко

				//- Заголовок H1
				h1.section-hero__title.t-h1
					span.section-hero__title-text Стильный ведущий
					span.section-hero__title-text для важных событий

				//- Гео/Подзаголовок
				p.section-hero__subtitle Москва и МО / Выезд

				//- Кнопка
				button.section-hero__btn.btn Узнать свободна ли дата
						a(href="#promo").top-menu__link.anchor-link Видео
					li.top-menu__item
						a(href=("#about")).top-menu__link.anchor-link О нас
					li.top-menu__item
						a(href=("#service")).top-menu__link.anchor-link Услуги
					li.top-menu__item
						a(href="#contacts").top-menu__link.anchor-link Контакты
			span.effect.filter
			span.effect.text.active.hidden
		.header__contacts 
			a.top-menu__link(href="tel:+9106071900") +7 910 607-19-00
			.header__burger-button
				include @/pug/assets/burger-button
